#!/usr/bin/env python3
"""life-statusline: minimal claude code footer — ctx + done today."""

import json
import sqlite3
import sys
from datetime import datetime
from pathlib import Path


def q(conn, sql, *args):
    try:
        return conn.execute(sql, args).fetchone()
    except Exception:
        return None


def format_tokens(n):
    if n >= 1_000:
        k, r = n // 1_000, (n % 1_000) // 100
        return f"{k}.{r}K" if r else f"{k}K"
    return str(n)


def read_last_time(session_id):
    """mtime of the claude code transcript JSONL — walks cwd ancestors for the project slug."""
    if not session_id:
        return None
    projects_dir = Path.home() / ".claude" / "projects"
    filename = f"{session_id}.jsonl"
    d = Path.cwd()
    while True:
        slug = str(d).replace("/", "-")
        jsonl = projects_dir / slug / filename
        try:
            mtime = jsonl.stat().st_mtime
            return datetime.fromtimestamp(mtime).strftime("%-I:%M%p").lower()
        except OSError:
            pass
        if d.parent == d:
            return None
        d = d.parent


def main():
    buf = sys.stdin.read()
    data = json.loads(buf) if buf.strip() else {}

    db_path = Path.home() / ".life/life.db"
    try:
        conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    except Exception:
        print("life ?", end="")
        return

    habits_done = (q(conn, """
        SELECT COUNT(*) FROM habit_checks hc
        JOIN habits h ON h.id = hc.habit_id
        WHERE hc.check_date = date('now', 'localtime')
        AND h.id NOT IN (SELECT habit_id FROM tags WHERE tag = 'vice' AND habit_id IS NOT NULL)
    """) or [0])[0]
    habits_total = (q(conn, """
        SELECT COUNT(*) FROM habits
        WHERE archived_at IS NULL AND deleted_at IS NULL AND cadence='daily'
        AND id NOT IN (SELECT habit_id FROM tags WHERE tag = 'vice' AND habit_id IS NOT NULL)
    """) or [0])[0]
    tasks_done = (q(conn, """
        SELECT COUNT(*) FROM tasks
        WHERE deleted_at IS NULL
        AND date(completed_at, 'localtime') = date('now', 'localtime')
    """) or [0])[0]
    tasks_scheduled = (q(conn, """
        SELECT COUNT(*) FROM tasks
        WHERE deleted_at IS NULL
        AND date(scheduled_for, 'localtime') = date('now', 'localtime')
    """) or [0])[0]
    done_today = habits_done + tasks_done
    total_today = habits_total + tasks_scheduled

    conn.close()

    # context window — match brr-statusline token calc
    usage = data.get("context_window", {}).get("current_usage", {})
    if isinstance(usage, dict):
        used = usage.get("input_tokens", 0) + usage.get("cache_creation_input_tokens", 0) + usage.get("cache_read_input_tokens", 0)
    else:
        used = usage or 0
    total = data.get("context_window", {}).get("context_window_size", 200_000)
    pct = (used * 100) // total if total else 0

    dim = "\x1b[2m"
    reset = "\x1b[0m"
    red = "\x1b[31m"
    yellow = "\x1b[33m"
    cyan = "\x1b[36m"
    purple = "\x1b[38;5;141m"
    mustard = "\x1b[38;5;178m"
    green = "\x1b[38;5;114m"

    parts = []

    if used > 0:
        ctx_color = cyan if pct < 50 else (yellow if pct < 80 else red)
        parts.append(f"{dim}ctx{reset} {ctx_color}{format_tokens(used)}{reset}")

    last = read_last_time(data.get("session_id", ""))
    if last:
        parts.append(f"{dim}last{reset} {purple}{last}{reset}")

    gray = "\x1b[38;5;240m"
    done_color = green if done_today >= 5 else (yellow if done_today >= 2 else mustard)
    parts.append(f"{dim}done{reset} {done_color}{done_today}{reset}{gray}/{total_today}{reset}")

    print("  ".join(parts), end="")


if __name__ == "__main__":
    main()
