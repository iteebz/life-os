#!/usr/bin/env python3
"""steward-statusline: life state footer for claude code."""

import json
import sqlite3
import sys
from pathlib import Path


def query(conn, sql, *args):
    try:
        return conn.execute(sql, args).fetchone()
    except Exception:
        return None


def main():
    buf = sys.stdin.read()
    data = json.loads(buf) if buf.strip() else {}

    db_path = Path.home() / ".life/life.db"
    try:
        conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    except Exception:
        print("steward ?")
        return

    tasks_open = (query(conn, "SELECT COUNT(*) FROM tasks WHERE completed_at IS NULL AND deleted_at IS NULL AND parent_id IS NULL") or [0])[0]
    habits_done = (query(conn, "SELECT COUNT(*) FROM habit_checks WHERE check_date = date('now')") or [0])[0]
    habits_total = (query(conn, "SELECT COUNT(*) FROM habits WHERE archived_at IS NULL AND deleted_at IS NULL AND cadence='daily'") or [0])[0]
    welfare_row = query(conn, "SELECT AVG(welfare) FROM sessions WHERE welfare IS NOT NULL AND logged_at >= datetime('now', '-100 days')")
    welfare = round(welfare_row[0]) if welfare_row and welfare_row[0] is not None else None

    conn.close()

    # context window
    used = data.get("context_window", {}).get("current_usage", 0)
    total = data.get("context_window", {}).get("context_window_size", 200_000)
    pct = used * 100 // total if total else 0

    dim = "\x1b[2m"
    reset = "\x1b[0m"
    red = "\x1b[31m"
    yellow = "\x1b[33m"
    cyan = "\x1b[36m"
    green = "\x1b[32m"

    # habits color: green if all done, yellow if partial, red if none
    if habits_done == 0:
        habit_color = red
    elif habits_done >= habits_total:
        habit_color = green
    else:
        habit_color = yellow

    # welfare color
    if welfare is None:
        w_str = "?"
        w_color = dim
    elif welfare >= 7:
        w_str = str(welfare)
        w_color = green
    elif welfare >= 4:
        w_str = str(welfare)
        w_color = yellow
    else:
        w_str = str(welfare)
        w_color = red

    parts = [
        f"{dim}tasks{reset} {tasks_open}",
        f"{dim}habits{reset} {habit_color}{habits_done}/{habits_total}{reset}",
        f"{dim}w{reset} {w_color}{w_str}{reset}",
    ]

    if used > 0:
        ctx_color = cyan if pct < 50 else (yellow if pct < 80 else red)
        parts.append(f"{dim}ctx{reset} {ctx_color}{pct}%{reset}")

    print("  ".join(parts), end="")


if __name__ == "__main__":
    main()
