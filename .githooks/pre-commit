#!/usr/bin/env bash
set -e

# Enforce for everyone — commit quality isn't agent-specific

DELETED=$(git diff --cached --name-only --diff-filter=D | wc -l | tr -d ' ')
if [ "$DELETED" -ge 50 ]; then
    echo "pre-commit: refusing commit — $DELETED staged deletions (threshold: 50)" >&2
    echo "  If intentional, bypass with: git commit --no-verify" >&2
    exit 1
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
[ -z "$STAGED" ] && exit 0

uv run ruff format $STAGED
uv run ruff check --fix $STAGED
git add $STAGED
